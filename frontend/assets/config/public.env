# Public-only dev config bundled as a Flutter asset.
#
# Loaded by `loadRepoDotenv()` as a LAST-RESORT fallback when the app was NOT
# launched with `--dart-define-from-file=../.env` (e.g. running from Xcode for
# StoreKit Configuration testing). Dart-defines always take precedence.
#
# NEVER put secrets here — this file ships inside the app bundle.
# For local-backend testing (LAN/ngrok), override via
# `--dart-define-from-file=../.env` instead of editing this file — a dev
# tunnel URL here would ship in the bundle and release builds refuse ngrok
# URLs at startup (see api_client.dart).

API_BASE_URL=https://rachae-flutter-production-11b3.up.railway.app/api/v1/

# RevenueCat public SDK key (publishable, not secret).
REVENUECAT_IOS_API_KEY=appl_kfdIbwsGxXmNzVxJBwFBkTufgcY
