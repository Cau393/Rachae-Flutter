# Rachae environment template — copy to `.env` and fill in.
# The backend reads this file from the repo root (config/settings.py -> ROOT_DIR/.env).

# ─── Required (Django will not start without these) ──────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_ORIGIN_REGEXES=
DATABASE_URL=postgres://user:password@localhost:5432/rachae

# ─── Redis / Celery (defaults to local Redis if unset) ───────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Supabase (JWT auth) ─────────────────────────────────────────────────────
SUPABASE_URL=

# ─── Firebase Cloud Messaging (push notifications) — OPTIONAL ────────────────
# FIREBASE_CREDENTIALS_JSON is a FILE PATH to a service-account JSON, not the
# JSON content. Relative paths resolve against the repo root.
#   - Leave it UNSET to run without push notifications (FCM degrades gracefully).
#   - If you SET it, the file MUST exist or startup/collectstatic will crash with
#     ImproperlyConfigured. On Railway/containers there is no persistent place to
#     put a secret file during build — leave this unset there (see README).
# FIREBASE_CREDENTIALS_JSON=backend/.secrets/firebase-credentials.json
# Set to 1 if the file exists but firebase-admin is not installed in this venv.
# FIREBASE_SKIP_INIT=0

# ─── Email (Brevo) — OPTIONAL ────────────────────────────────────────────────
BREVO_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=Rachae
FRONTEND_URL=https://app.rachae.app
FRONTEND_INVITE_URL=http://localhost:3000/login

# ─── AWS S3 (receipt storage) — OPTIONAL ─────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION=sa-east-1
AWS_S3_BUCKET=rachae-receipts
CLOUDFRONT_DOMAIN=

# ─── Stripe / RevenueCat (billing) — OPTIONAL ────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
REVENUECAT_WEBHOOK_SECRET=

# ─── Misc — OPTIONAL ─────────────────────────────────────────────────────────
EXCHANGE_RATE_API_KEY=
SENTRY_DSN=
